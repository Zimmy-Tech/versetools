# VerseTools API — Local development environment variables
#
# Copy this file to `.env` (same directory) and fill in the values below.
# `.env` is gitignored so secrets stay local. In production, these are
# set via DigitalOcean App Platform's env var settings, not via this file.
#
#   cp api/.env.example api/.env
#   # then edit api/.env with your real values
#
# After editing, restart the API: `cd api && node server.js`
# (or `npm run dev` if a dev script is added later)

# ----- Database -----
#
# Postgres connection string. For local development, use a Neon dev branch
# (the "dev" branch in your Neon project mirrors production data with
# copy-on-write isolation — writes don't affect prod). Get the URL from:
#
#   Neon dashboard → your project → Branches → dev → Connection Details
#
# It will look like: postgres://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/DBNAME?sslmode=require
#
# DO NOT put the production database URL here. Local writes WILL hit
# whatever database this points at.
DATABASE_URL=

# ----- Auth -----
#
# JWT secret used to sign admin login tokens. Any random string works for
# local dev — production has its own value set in DO. The value below was
# generated fresh and is fine to use as-is for local development.
JWT_SECRET=5wo4gfX7XvfSjd_MUid52Ft4l29xfpeoNfLymvX5bogAUFsVgsIbxJZKjxpsJCOb

# Admin login credentials for the local admin panel. Pick anything you'll
# remember; these only matter for *your* local environment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=devpass

# ----- Server -----
#
# Port the API listens on locally. Defaults to 3000 if unset. The Angular
# dev server at http://localhost:4200 is configured (via CORS) to talk to
# this port.
PORT=3000
