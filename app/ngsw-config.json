{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationUrls": [
    "/**",
    "!/api/**"
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/ship-images/**",
          "/power-icons/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "app-data",
      "urls": [
        "/**/versedb_*.json",
        "/config.json",
        "/version.json"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 32,
        "maxAge": "1h",
        "timeout": "10s"
      }
    }
  ]
}
